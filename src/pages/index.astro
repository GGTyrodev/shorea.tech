---
import Layout from "../layouts/Layout.astro";
import "../styles/home.css";
import CaseStudyCard from "../components/CaseStudyCard.astro";
import Pill from "../components/Pill.astro";
import type { WorkItem } from "../types/portfolio";

const work = [
  {
    company: "DANA",
    url: "https://www.dana.id/",
    role: "Senior Software Engineer",
    period: "October 2019 - May 2026",
    accent: "blue",
    summary:
      "Contributed to customer-facing financial experiences in a cross-functional product team. Replace this example with your exact, approved scope.",
    tags: ["Product engineering", "Reliability", "Fintech"],
    contribution:
      "Add the feature, system, or problem you personally worked on.",
    outcome: "Add an approved result, public metric, or qualitative outcome.",
  },
  {
    company: "OVO",
    url: "https://www.ovo.id/",
    role: "Software Engineer",
    period: "Add your dates",
    accent: "purple",
    summary:
      "Worked with engineering and product partners on dependable digital payment journeys. Replace this example with your exact, approved scope.",
    tags: ["Payments", "Collaboration", "Scale"],
    contribution:
      "Describe your ownership without claiming the work of the wider team.",
    outcome:
      "Use numbers only when they are public or approved for disclosure.",
  },
] satisfies WorkItem[];
---

<Layout
  title="Portfolio | Software Engineer"
  description="Selected fintech work, engineering case studies, and independent projects."
>
  <header class="site-header">
    <a class="brand" href={`${import.meta.env.BASE_URL}/`} aria-label="Home">
      <span class="brand-mark">S</span>
      <span>shorea / portfolio</span>
    </a>
    <nav aria-label="Main navigation">
      <a href="#work">Work</a>
      <a href="#about">About</a>
      <a href="#contact">Contact</a>
    </nav>
  </header>

  <main>
    <section class="hero" aria-labelledby="hero-title">
      <div class="eyebrow">
        <span class="status-dot"></span> Software engineer in Indonesia
      </div>
      <h1 id="hero-title">
        I build dependable products for <em>everyday moments.</em>
      </h1>
      <div class="hero-footer">
        <p>
          A portfolio of product engineering work across fintech, payments, and
          independent experiments.
        </p>
        <a class="round-link" href="#work" aria-label="View selected work"
          >&darr;</a
        >
      </div>
    </section>

    <section class="work-section" id="work" aria-labelledby="work-title">
      <div class="section-heading">
        <p class="section-number">01</p>
        <div>
          <p class="kicker">Selected work</p>
          <h2 id="work-title">Experience, explained clearly.</h2>
        </div>
      </div>

      <p class="template-note">
        <strong>Template note:</strong> replace the example copy below with details
        you are allowed to share. The visual placeholders can hold approved screenshots,
        diagrams, or public marketing images.
      </p>

      <div class="work-list">
        {
          work.map((item, index) => (
            <CaseStudyCard item={item} index={index} total={work.length} />
          ))
        }
      </div>
    </section>

    <section class="about-section" id="about" aria-labelledby="about-title">
      <div class="section-heading light">
        <p class="section-number">02</p>
        <div>
          <p class="kicker">About</p>
          <h2 id="about-title">Engineering with context.</h2>
        </div>
      </div>
      <div class="about-grid">
        <p class="about-lead">
          I care about the space between a technically correct solution and a
          product people can depend on.
        </p>
        <div class="about-copy">
          <p>
            Write two short paragraphs about how you work: the problems you
            enjoy, how you collaborate, and the engineering qualities you value.
          </p>
          <p>
            Keep the biography human and specific. Your work cards already cover
            technologies; this section should explain your point of view.
          </p>
        </div>
      </div>
    </section>

    <section
      class="contact-section"
      id="contact"
      aria-labelledby="contact-title"
    >
      <p class="kicker">03 / Contact</p>
      <h2 id="contact-title">Have an interesting problem?</h2>
      <div class="contact-links">
        <Pill
          label="Email"
          variant="navigation"
          href="mailto:ghean.tyrodev@gmail.com"
        />
        <Pill
          label="GitHub"
          variant="navigation"
          href="https://github.com/GGTyrodev"
          external
        />
        <Pill
          label="LinkedIn"
          variant="navigation"
          href="https://www.linkedin.com/in/ghean-ginanjar-adiguna/"
        />
      </div>
    </section>
  </main>

  <footer>
    <span>Built with Astro</span>
    <span>Indonesia &middot; {new Date().getFullYear()}</span>
  </footer>
</Layout>
