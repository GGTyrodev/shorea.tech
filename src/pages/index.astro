---
import Layout from "../layouts/Layout.astro";
import "../styles/home.css";
import CaseStudyCard from "../components/CaseStudyCard.astro";
import Pill from "../components/Pill.astro";
import Brand from "../components/Brand.astro";
import ProfileCard from "../components/ProfileCard.astro";
import danaImage from "../assets/dana-appr.png";
import ovoImage from "../assets/ovo-appr.png";
import type { WorkItem } from "../types/portfolio";

const work = [
  {
    company: "DANA",
    url: "https://www.dana.id/",
    role: "Senior Software Development Engineer (iOS & Web)",
    period: "October 2019 - May 2026",
    accent: "blue",
    summary:
      "Contributed to DANA's consumer fintech platform across iOS and mobile web, focusing on application performance, core user systems, modular architecture, and engineering productivity.",
    tags: ["iOS Engineering", "Performance", "CI/CD", "Fintech"],
    image: danaImage.src,
    impact: [
      "Reduced iOS startup time from approximately 12 seconds to 4-5 seconds by profiling and redesigning initialization flows.",
      "Led four engineers responsible for core authentication and user systems.",
      "Established DANA's early iOS CI/CD process with Jenkins and Fastlane, targeting a 9-minute build, 1-minute test run, and 1-minute feedback loop.",
    ],
  },
  {
    company: "OVO",
    url: "https://www.ovo.id/",
    role: "iOS Developer",
    period: "February 2016 - October 2019",
    accent: "purple",
    summary:
      "Contributed to OVO's iOS application during its early growth into a large-scale digital wallet, helping expand the product while strengthening its technical foundations.",
    tags: ["iOS Engineering", "MVVM", "Reactive Programming", "Fintech"],
    image: ovoImage.src,
    impact: [
      "Helped develop and scale OVO's iOS application during its early growth.",
      "Contributed to the migration from MVC to MVVM, improving maintainability and scalability.",
      "Adopted reactive programming patterns and integrated services including AppsFlyer.",
    ],
  },
] satisfies WorkItem[];
---

<Layout
  title="Portfolio | Software Engineer"
  description="Selected fintech work, engineering case studies, and independent projects."
>
  <header class="site-header">
    <Brand />
    <nav aria-label="Main navigation">
      <a href="#work">Work</a>
      <a href="#about">About</a>
      <a href="#contact">Contact</a>
    </nav>
  </header>

  <main>
    <section class="hero" aria-labelledby="hero-title">
      <ProfileCard
        position="Senior Software Developement Engineer (iOS / H5)"
      />
      <h1 id="hero-title">
        Built and scaled apps <em>used by tens of millions of users.</em>
      </h1>
      <div class="hero-footer">
        <p>
          A portfolio of product engineering work across fintech, payments, and
          independent experiments.
        </p>
      </div>
    </section>

    <section class="work-section" id="work" aria-labelledby="work-title">
      <div class="section-heading">
        <p class="section-number">01</p>
        <div>
          <p class="kicker">Selected work</p>
          <h2 id="work-title">
            Experience across fintech and large-scale consumer systems
          </h2>
        </div>
      </div>

      <div class="work-list">
        {
          work.map((item, index) => (
            <CaseStudyCard item={item} index={index} total={work.length} />
          ))
        }
      </div>
    </section>

    <section class="about-section" id="about" aria-labelledby="about-title">
      <div class="section-heading light">
        <p class="section-number">02</p>
        <div>
          <p class="kicker">About</p>
          <h2 id="about-title">Engineering with context.</h2>
        </div>
      </div>
      <div class="about-grid">
        <p class="about-lead">
          13+ years improving the performance, architecture, and delivery of
          high-scale fintech products.
        </p>
        <ul class="about-evidence">
          <li>
            Reduced DANA's iOS startup time from approximately <strong
              >12s to 4-5s</strong
            >.
          </li>
          <li>
            Led <strong>four engineers</strong> responsible for authentication
            and user systems.
          </li>
          <li>
            Helped evolve OVO's iOS architecture from <strong>MVC to MVVM</strong>
            during rapid growth.
          </li>
          <li>
            Established DANA's early iOS CI/CD process with Jenkins and Fastlane
            around the <strong>9-1-1 efficiency target</strong>: 9-minute builds,
            1-minute tests, and 1-minute feedback.
          </li>
          <li>
            Drove modular development across multiple DANA capabilities, with
            <strong>end-to-end ownership of the passkey module</strong>.
          </li>
        </ul>
      </div>
    </section>

    <section
      class="contact-section"
      id="contact"
      aria-labelledby="contact-title"
    >
      <p class="kicker">03 / Contact</p>
      <h2 id="contact-title">Have an interesting problem?</h2>
      <div class="contact-links">
        <Pill
          label="Email"
          variant="navigation"
          href="mailto:ghean.tyrodev@gmail.com"
        />
        <Pill
          label="GitHub"
          variant="navigation"
          href="https://github.com/GGTyrodev"
          external
        />
        <Pill
          label="LinkedIn"
          variant="navigation"
          href="https://www.linkedin.com/in/ghean-ginanjar-adiguna/"
        />
      </div>
    </section>
  </main>

  <footer>
    <span>Built with Astro</span>
    <span>Indonesia &middot; {new Date().getFullYear()}</span>
  </footer>
</Layout>
