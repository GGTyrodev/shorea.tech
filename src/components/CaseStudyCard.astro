---
import Pill from './Pill.astro';
import type { WorkItem } from '../types/portfolio';

interface Props {
	item: WorkItem;
	index: number;
	total: number;
}

const { item, index, total } = Astro.props;
const position = String(index + 1).padStart(2, '0');
const count = String(total).padStart(2, '0');
const hasImage = item.image.trim().length > 0;
---

<article class={`case-study ${item.accent}`}>
	<div class="case-copy">
		<div class="case-topline">
			<span>{position} / {count}</span>
			<span>{item.period}</span>
		</div>
		<h3>{item.company}</h3>
		<p class="role">{item.role}</p>
		<p class="summary">{item.summary}</p>

		<dl>
			<div>
				<dt>My contribution</dt>
				<dd>{item.contribution}</dd>
			</div>
			<div>
				<dt>Outcome</dt>
				<dd>{item.outcome}</dd>
			</div>
		</dl>

		<div class="tags" aria-label="Areas of work">
			{item.tags.map((tag) => <Pill label={tag} />)}
		</div>
		<Pill label="Visit public product" variant="navigation" href={item.url} external />
	</div>

	<div
		class:list={['case-visual', { 'has-image': hasImage }]}
		aria-label={!hasImage ? `Screenshot placeholder for ${item.company}` : undefined}
	>
		{hasImage ? (
			<img src={item.image} alt={`${item.company} project screenshot`} loading="lazy" />
		) : (
			<>
				<div class="visual-label">Approved visual goes here</div>
				<div class="phone">
					<div class="phone-bar"><span></span></div>
					<div class="phone-content">
						<div class="ui-brand">{item.company}</div>
						<div class="ui-balance"></div>
						<div class="ui-actions"><span></span><span></span><span></span></div>
						<div class="ui-card"></div>
						<div class="ui-lines"><span></span><span></span><span></span></div>
					</div>
				</div>
				<p>Use a cropped screen or a sanitized architecture diagram.</p>
			</>
		)}
	</div>
</article>

<style>
	.case-study {
		display: grid;
		min-height: 690px;
		grid-template-columns: minmax(0, 1fr) minmax(380px, 0.85fr);
		color: var(--color-ink);
		background: #e8e5de;
		overflow: hidden;
	}

	.case-copy {
		display: flex;
		padding: clamp(28px, 5vw, 68px);
		align-items: flex-start;
		flex-direction: column;
	}

	.case-topline,
	.visual-label {
		font-family: var(--font-mono);
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.case-topline {
		display: flex;
		width: 100%;
		justify-content: space-between;
		padding-bottom: 24px;
		border-bottom: 1px solid rgba(25, 25, 22, 0.2);
		color: #6b6962;
	}

	h3 {
		margin: 48px 0 0;
		font-family: var(--font-serif);
		font-size: clamp(58px, 8vw, 112px);
		font-weight: 400;
		letter-spacing: -0.07em;
		line-height: 0.9;
	}

	.role {
		margin: 20px 0 0;
		font-family: var(--font-mono);
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.summary {
		max-width: 600px;
		margin: 36px 0;
		font-size: clamp(18px, 2vw, 23px);
		line-height: 1.5;
	}

	dl {
		display: grid;
		width: 100%;
		margin: auto 0 32px;
		grid-template-columns: 1fr 1fr;
		gap: 24px;
	}

	dt {
		margin-bottom: 8px;
		font-family: var(--font-mono);
		font-size: 10px;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	dd {
		margin: 0;
		color: #57554f;
		font-size: 14px;
	}

	.tags {
		display: flex;
		margin-bottom: 28px;
		gap: 8px;
		flex-wrap: wrap;
	}

	.case-visual {
		position: relative;
		display: flex;
		min-height: 540px;
		padding: 32px;
		align-items: center;
		justify-content: center;
		flex-direction: column;
		overflow: hidden;
	}

	.case-visual::before,
	.case-visual::after {
		position: absolute;
		width: 240px;
		height: 240px;
		border: 1px solid rgba(255, 255, 255, 0.28);
		border-radius: 50%;
		content: '';
	}

	.case-visual::before {
		top: -80px;
		right: -40px;
	}

	.case-visual::after {
		bottom: -130px;
		left: -30px;
		width: 330px;
		height: 330px;
	}

	.case-visual.has-image {
		padding: 0;
	}

	.case-visual.has-image::before,
	.case-visual.has-image::after {
		display: none;
	}

	.case-visual > img {
		display: block;
		width: auto;
		max-width: 100%;
		height: 100%;
		min-height: inherit;
		object-fit: contain;
	}

	.blue .case-visual {
		background: #2c7be5;
	}

	.purple .case-visual {
		background: #6c3ca5;
	}

	.visual-label {
		position: absolute;
		top: 24px;
		left: 28px;
		color: rgba(255, 255, 255, 0.72);
	}

	.phone {
		position: relative;
		z-index: 2;
		width: min(290px, 75%);
		padding: 10px;
		border: 1px solid rgba(255, 255, 255, 0.45);
		border-radius: 36px;
		background: rgba(16, 16, 15, 0.88);
		box-shadow: 0 36px 70px rgba(17, 17, 16, 0.26);
		transform: rotate(3deg);
	}

	.phone-bar {
		display: grid;
		height: 28px;
		place-items: center;
	}

	.phone-bar span {
		display: block;
		width: 70px;
		height: 5px;
		border-radius: 999px;
		background: #393936;
	}

	.phone-content {
		min-height: 465px;
		padding: 25px 18px;
		border-radius: 26px;
		background: #f6f3ed;
	}

	.ui-brand {
		font-family: var(--font-mono);
		font-size: 13px;
		font-weight: 900;
		letter-spacing: 0.08em;
	}

	.ui-balance {
		height: 92px;
		margin-top: 24px;
		border-radius: 16px;
		background: linear-gradient(135deg, rgba(25, 25, 22, 0.88), rgba(25, 25, 22, 0.62));
	}

	.ui-actions {
		display: flex;
		margin: 24px 4px;
		justify-content: space-between;
	}

	.ui-actions span {
		display: block;
		width: 42px;
		height: 42px;
		border-radius: 50%;
		background: #dedbd4;
	}

	.ui-card {
		height: 112px;
		border-radius: 16px;
		background: #e5e1d9;
	}

	.ui-lines {
		display: grid;
		margin-top: 22px;
		gap: 11px;
	}

	.ui-lines span {
		display: block;
		height: 7px;
		border-radius: 999px;
		background: #d4d0c9;
	}

	.ui-lines span:nth-child(2) {
		width: 75%;
	}

	.ui-lines span:nth-child(3) {
		width: 52%;
	}

	.case-visual > p {
		position: absolute;
		z-index: 3;
		right: 24px;
		bottom: 18px;
		left: 24px;
		margin: 0;
		color: rgba(255, 255, 255, 0.72);
		font-size: 11px;
		text-align: center;
	}

	@media (max-width: 860px) {
		.case-study {
			grid-template-columns: 1fr;
		}

		.case-visual {
			min-height: 620px;
		}
	}

	@media (max-width: 560px) {
		.case-copy {
			padding: 28px 22px 36px;
		}

		h3 {
			margin-top: 36px;
		}

		dl {
			grid-template-columns: 1fr;
		}

		.case-visual {
			min-height: 560px;
		}

		.phone {
			width: min(260px, 82%);
		}

		.phone-content {
			min-height: 420px;
		}
	}
</style>
