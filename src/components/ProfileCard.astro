---
import profileImg from "../assets/PP-Linkedin.jpg";

interface Props {
  name?: string;
  position?: string;
}

const {
  name = "Ghean Ginanjar Adiguna",
  position = "Software Engineer"
} = Astro.props;
---

<div class="profile-card">
  <div class="profile-image">
    <img src={profileImg.src} alt={`${name} profile photo`} />
  </div>
  <div class="profile-text">
    <p class="profile-name">{name}</p>
    <p class="profile-position">{position}</p>
  </div>
</div>

<style>
  .profile-card {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .profile-image {
    flex-shrink: 0;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid rgba(25, 25, 22, 0.1);
  }

  .profile-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .profile-text {
    display: flex;
    flex-direction: column;
  }

  .profile-name {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 500;
    line-height: 1.2;
    color: var(--color-ink);
  }

  .profile-position {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 24px;
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--color-ink);
    opacity: 0.7;
  }

  @media (max-width: 640px) {
    .profile-image {
      width: 80px;
      height: 80px;
    }

    .profile-name {
      font-size: 18px;
    }

    .profile-position {
      font-size: 18px;
    }
  }
</style>
